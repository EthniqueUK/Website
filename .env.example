# Supabase — use Publishable + Secret keys (Settings → API Keys)
# Legacy anon / service_role JWT keys are deprecated; see:
# https://supabase.com/docs/guides/getting-started/migrating-to-new-api-keys

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# App URL (used in invite / onboarding email links)
NEXT_PUBLIC_APP_URL=http://localhost:3005

# Resend (seller onboarding emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Ethnique <hello@ethnique.co.uk>
ADMIN_NOTIFICATION_EMAIL=
